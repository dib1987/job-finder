# Job Finder — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git

# ── LLM ──────────────────────────────────────────────────────────────
# Primary: Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# Model selection (claude-sonnet-4-6 recommended for scoring quality vs cost)
# Other options: claude-opus-4-6, gpt-4o, gemini-1.5-pro
LLM_MODEL=claude-sonnet-4-6

# ── LinkedIn ─────────────────────────────────────────────────────────
# Your LinkedIn login credentials (used only for one-time session setup)
LINKEDIN_EMAIL=you@example.com
LINKEDIN_PASSWORD=your_password_here

# Path to saved Playwright session (generated by --setup-linkedin)
LINKEDIN_SESSION_PATH=config/linkedin_session.json

# ── Job Source ───────────────────────────────────────────────────────
# Options: linkedin_scraper | rapidapi
# Switch to rapidapi when you have a RapidAPI key — zero code changes
JOB_SOURCE=linkedin_scraper

# RapidAPI key (only needed if JOB_SOURCE=rapidapi)
RAPIDAPI_KEY=

# ── Email Notifications ──────────────────────────────────────────────
# Gmail account to SEND from (needs App Password, not your Gmail password)
# Guide: https://support.google.com/accounts/answer/185833
SMTP_EMAIL=you@gmail.com
SMTP_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Email to RECEIVE daily reports
NOTIFY_EMAIL=you@example.com

# ── Behavior ─────────────────────────────────────────────────────────
# Set to true to run full pipeline without actually submitting applications
DRY_RUN=false

# Score threshold — jobs below this score are ignored entirely
SCORING_THRESHOLD=70

# Maximum jobs to scrape per run (keep ≤30 to reduce LinkedIn ban risk)
MAX_JOBS_PER_RUN=30
